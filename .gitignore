# ===== 敏感材料：标书原文/甲方材料，仅本地留存，不入公开仓 =====
docs/*.docx
docs/*.doc
docs/*.pdf
docs/**/*.docx
*.标书.*

# ===== OS / IDE =====
.DS_Store
Thumbs.db
.idea/
.vscode/
*.iml
*.swp

# ===== Java =====
target/
build/
*.class
*.log
.gradle/
hs_err_pid*

# ===== Node / TS =====
node_modules/
dist/
.next/
out/
*.tsbuildinfo
.pnpm-store/

# ===== Python =====
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/

# ===== 本地环境 / 机密 =====
.env
.env.local
*.local
secrets/
*.pem
*.key

# 红线 denylist：真实代号/客户术语词表仅本地留存，不入库
libs-java/scripts/.redline-denylist

# ===== 本地调试产物（Playwright MCP 会话日志 / 验证截图），可重生，不入库 =====
.playwright-mcp/
console-home.png

# ===== Helm（deploy/）=====
# umbrella vendored 子 chart（helm dependency build 产物，可重建，不入库）
deploy/charts/*/charts/
# 渲染产物
deploy/**/*.rendered.yaml
# 红线：明文 Secret 实体一律不入库（ESO 注入）。
# 注意用否定放行 ESO 的 ExternalSecret/SecretStore CR——它们只引用外部路径、无明文，必须入库。
**/*secret*.yaml
**/*secret*.yml
!**/externalsecret*.yaml
!**/externalsecret*.yml
!**/secretstore*.yaml
!**/clustersecretstore*.yaml
